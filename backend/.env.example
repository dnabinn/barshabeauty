# Server
PORT=3000
FRONTEND_URL=https://barshabeautysalon.pt

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Stripe — Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# (the matching publishable key goes in /js/config.js as STRIPE_PUBLIC_KEY, not here)

# Resend — resend.com/api-keys (used for booking confirmation + contact form emails)
RESEND_API_KEY=re_xxx
EMAIL_FROM=reservas@barshabeautysalon.pt
OWNER_EMAIL=geral@barshabeautysalon.pt

# Admin panel password (sent as x-admin-password header from pages/admin.html)
ADMIN_PASSWORD=change-me
